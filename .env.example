# ── CUDE Enterprise Platform — Environment Configuration ─────────────────────

# Backend port (default: 3001)
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cude:cude_dev_pass@localhost:5432/cude
POSTGRES_PASSWORD=cude_dev_pass

# ── Redis (job queue + cache + SSE pub/sub) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-compatible object store) ───────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=cude-admin
MINIO_SECRET_KEY=cude-secret-key-change-me
MINIO_USE_SSL=false

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=24h

# ── AI API Keys (optional — mocks used if not set) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ── Feature Flags ────────────────────────────────────────────────────────────
# Set to false to use in-memory storage (demo mode, no PostgreSQL needed)
USE_DATABASE=true
