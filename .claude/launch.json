{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cude-app",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http');const s=h.createServer((q,r)=>{const p=h.request({hostname:'localhost',port:3001,path:q.url,method:q.method,headers:q.headers},pr=>{r.writeHead(pr.statusCode,pr.headers);pr.pipe(r)});q.pipe(p);p.on('error',()=>{r.writeHead(502);r.end('Backend unavailable')})});s.listen(3002,()=>console.log('Proxy on 3002'))"],
      "port": 3002
    }
  ]
}
